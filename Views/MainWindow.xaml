<Window x:Class="WarpManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:conv="clr-namespace:WarpManager.Converters"
        xmlns:vm="clr-namespace:WarpManager.ViewModels"
        xmlns:models="clr-namespace:WarpManager.Models"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="WARP Manager"
        Width="600" MinWidth="600"
        MinHeight="800" Height="800">

    <Window.Resources>
        <conv:StatusToBrushConverter  x:Key="StatusToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="RemoveItemButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Content" Value="✕"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="StretchListBox" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status row -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Ellipse Width="14" Height="14"
                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </ui:SimpleStackPanel>

            <Button Grid.Column="1"
                    Content="↺ Refresh"
                    Command="{Binding RefreshCommand}"
                    MinWidth="90"/>
        </Grid>

        <!-- Toggle WARP button -->
        <Button Grid.Row="1"
                Content="{Binding ToggleLabel}"
                Command="{Binding ToggleWarpCommand}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,12"
                Style="{StaticResource AccentButtonStyle}"/>

        <!-- Tabs -->
        <TabControl Grid.Row="2" x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">

            <!-- IP / CIDR tab -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run Text="IP / CIDR ("/>
                        <Run Text="{Binding IpExclusions.Count, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </TabItem.Header>
                <ListBox ItemsSource="{Binding IpExclusions}"
                         Style="{StaticResource StretchListBox}"
                         Margin="0,4,0,0"
                         MinHeight="140">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ExclusionItemViewModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Value}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource RemoveItemButton}"
                                        Command="{Binding RemoveCommand}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <!-- Hosts / Domains tab -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock>
                        <Run Text="Hosts / Domains ("/>
                        <Run Text="{Binding HostExclusions.Count, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </TabItem.Header>
                <ListBox ItemsSource="{Binding HostExclusions}"
                         Style="{StaticResource StretchListBox}"
                         Margin="0,4,0,0"
                         MinHeight="140">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ExclusionItemViewModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Value}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource RemoveItemButton}"
                                        Command="{Binding RemoveCommand}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>

        <!-- Bottom action row + spinner -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ui:SimpleStackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <Button x:Name="AddButton"
                        Content="Add IP/CIDR"
                        Command="{Binding AddExclusionCommand}"
                        CommandParameter="{x:Static models:ExclusionType.Ip}"
                        MinWidth="120"/>
                <Button x:Name="RemoveAllButton"
                        Content="Remove All"
                        Command="{Binding RemoveAllCommand}"
                        CommandParameter="{x:Static models:ExclusionType.Ip}"
                        MinWidth="120"/>
            </ui:SimpleStackPanel>

            <ProgressBar Grid.Row="1"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                         Height="4"
                         Margin="0,8,0,0"/>
        </Grid>
    </Grid>
</Window>
