<Window x:Class="WarpManager.Views.AddExclusionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Add Exclusion"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">
        <TextBlock x:Name="TitleText"
                   FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <ui:SimpleStackPanel Spacing="8">
            <TextBox x:Name="InputBox"
                     ui:ControlHelper.PlaceholderText="e.g. 192.168.1.0/24"
                     TextChanged="InputBox_TextChanged"/>

            <TextBlock x:Name="ValidationText"
                       Foreground="OrangeRed"
                       FontSize="12"
                       Visibility="Collapsed"/>

            <ui:SimpleStackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel" Click="Cancel_Click" MinWidth="80"/>
                <Button x:Name="AddButton"
                        Content="Add"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="Add_Click"
                        MinWidth="80"
                        Style="{StaticResource AccentButtonStyle}"/>
            </ui:SimpleStackPanel>
        </ui:SimpleStackPanel>
    </StackPanel>
</Window>
